# App Configuration
# Copy this file to .env and fill in your values.
# These are read at build time via app.config.ts and exposed through expo-constants.
# Never commit your .env file – it is listed in .gitignore.

# ---------------------------------------------------------------------------
# Firebase Web Client Configuration
# Find these values in Firebase Console → Project Settings → Your apps →
# SDK setup and configuration.
# ---------------------------------------------------------------------------
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# ---------------------------------------------------------------------------
# Google OAuth Client IDs  (required for Sign in with Google)
#
# How to obtain these IDs:
#   1. Go to Google Cloud Console → APIs & Services → Credentials.
#   2. Create OAuth 2.0 Client IDs for each platform you need.
#   3. Or find them in Firebase Console → Authentication → Sign-in method →
#      Google → Web client ID / Expand "Web SDK configuration".
#
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID (REQUIRED)
#   Type: Web application
#   Used by: Expo Go and all web-based OAuth flows.
#   Authorized redirect URIs: add https://auth.expo.io/@<your-expo-username>/CorsaNative
#   (see README for details)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID (recommended for iOS native builds)
#   Type: iOS
#   Bundle ID: com.corsanative
#   expo-auth-session uses the reversed client-ID scheme automatically;
#   no redirect URI registration is needed in Google Cloud for iOS.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id.apps.googleusercontent.com

# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID (recommended for Android native builds)
#   Type: Android
#   Package name: com.corsanative
#   SHA-1 certificate fingerprint: add your debug and release SHA-1 hashes.
#     Debug SHA-1 (macOS/Linux):
#       keytool -keystore ~/.android/debug.keystore -list -v -alias androiddebugkey -storepass android -keypass android
#     Also register your SHA-1 in Firebase Console → Project Settings →
#     Your Android app → Add fingerprint.
#   expo-auth-session uses com.googleusercontent.apps.{ID}://oauth2redirect/android
#   automatically; no redirect URI registration is needed for Android.
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id.apps.googleusercontent.com

# ---------------------------------------------------------------------------
# AWS AppSync
# ---------------------------------------------------------------------------
APPSYNC_API_KEY=your_appsync_api_key

# ---------------------------------------------------------------------------
# CloudFront
# ---------------------------------------------------------------------------
EXPO_PUBLIC_CLOUDFRONT_PHOTO_URL=https://your-distribution.cloudfront.net
